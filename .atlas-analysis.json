  "keyFeatures": [
    "Framework-agnostic consent management with React, Next.js, and vanilla JavaScript support",
    "GDPR, CCPA, and LGPD compliance out of the box",
    "Headless UI components with full customization",
    "Script loader with automatic consent gating",
    "Internationalization support with 40+ languages",
    "Self-hostable backend with multiple database adapters",
    "TypeScript-first with complete type safety",
    "Server-side rendering support",
    "Comprehensive CLI for scaffolding and migrations"
  ],
  "publicApiSurface": [
    "createConsentManagerStore() - Core consent state management",
    "ConsentProvider - React context provider",
    "CookieBanner - Prebuilt cookie banner component",
    "ConsentManagerDialog - Consent preferences dialog",
    "useConsent() - React hook for consent state",
    "useConsentBanner() - React hook for banner control",
    "loadScripts() - Dynamic script loader with consent gating",
    "saveConsentToStorage() - Persist consent to cookies/localStorage",
    "getConsentFromStorage() - Retrieve stored consent",
    "createTrackingBlocker() - Block tracking scripts until consent",
    "createIframeBlocker() - Block iframes until consent",
    "@c15t/backend - Self-hostable consent backend",
    "@c15t/cli - Command-line scaffolding tool",
    "@c15t/node-sdk - Node.js API client"
  ]
